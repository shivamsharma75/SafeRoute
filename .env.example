# ============================
# SafeRoute — Environment Variables
# Copy this file to .env and fill in your values
# ============================

# MongoDB Atlas — MUST start with mongodb+srv://
# Get from: https://cloud.mongodb.com → Connect → Connect your application
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/saferoute?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# CORS — frontend URL (Vercel in prod, localhost in dev)
CLIENT_URL=http://localhost:5173

# OSRM — Public demo server (free, no key needed)
# DO NOT change for demo — production would use a self-hosted instance
OSRM_BASE_URL=http://router.project-osrm.org

# Nominatim geocoding (free, no key needed — OSM)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
